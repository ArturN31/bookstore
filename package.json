{
    "name": "store",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "safe-install": "npm ci && npm audit signatures",
        "secure-check": "npm audit --audit-level=high",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest --coverage",
        "test:coverage": "jest --coverage --coverageReporters=\"json-summary\" --watchAll=false --forceExit",
        "test:generate-report": "node utils/scripts/generate-test-summary-file.js",
        "test:report": "node -e \"const { execSync } = require('child_process'); try { execSync('npm run test:coverage', { stdio: 'inherit' }); } catch (e) {} execSync('npm run test:generate-report', { stdio: 'inherit' });\"",
        "test:watch": "jest --watchAll"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.0",
        "@mui/icons-material": "^9.0.1",
        "@mui/material": "^9",
        "@mui/material-nextjs": "^9.0.1",
        "@supabase/ssr": "^0.12",
        "@supabase/supabase-js": "^2.97.0",
        "@tailwindcss/postcss": "^4.0.0",
        "@vercel/analytics": "^2.0.1",
        "next": "^16",
        "notistack": "^3.0.2",
        "react": "^19",
        "react-dom": "^19.1.1",
        "react-intersection-observer": "^10.0.3",
        "use-debounce": "^10.1.0",
        "zod": "^4"
    },
    "devDependencies": {
        "@faker-js/faker": "^10",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25",
        "@types/react": "^19.1.13",
        "@types/react-dom": "^19.1.9",
        "@types/testing-library__jest-dom": "^5.14.9",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.4",
        "jest": "^30.1.3",
        "jest-environment-jsdom": "^30.1.2",
        "postcss": "^8.5.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "supabase": "^2",
        "tailwindcss": "^4.0.0",
        "typescript": "^6"
    },
    "browserslist": [
        "last 2 Chrome versions",
        "last 2 Firefox versions",
        "last 2 Edge versions",
        "last 2 Safari versions"
    ]
}
